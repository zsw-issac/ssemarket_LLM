    "async def say_hello():\n",
    "    print(\"Hello\")\n",
    "    await asyncio.sleep(10)\n",
    "    print(\"world\")\n",
    "\n",
    "async def main():\n",
    "    await asyncio.gather(\n",
    "        say_hello(),\n",
    "        say_hello()\n",
    "    )\n",
    "\n",
    "if __name__==\"__main__\":\n",
    "    await main()"
   ]
